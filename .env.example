# ─────────────────────────────────────────────────────────────────
# Union Grievance Tracker — Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── App Security ──────────────────────────────────────────────────
# Password to access the Streamlit app
APP_PASSWORD=union2024

# ── Gemini AI ─────────────────────────────────────────────────────
# Get your free API key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Sheets ─────────────────────────────────────────────────
# Option A: Paste the full contents of your service account JSON (recommended for cloud)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "...", ...}

# Option B: Path to your service account JSON key file (easier for local dev)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
